doc/_build/

# PyBuilder
.pybuilder/
target/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# pyenv
#   For a library or app, you might want to share your .python-version.
#   Comment this line out if you want to check it in.
.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if delegates have different python versions, they may not be able to install the dependencies.
#   Pipfile.lock

# poetry
#   Similar to Pipenv, Poetry uses poetry.lock to control dependencies.
#   poetry.lock

# pdm
#   Similar to Pipenv, PDM uses pdm.lock to control dependencies.
#   pdm.lock
.pdm-plugins/
.pdm-build/

# virtualenv
venv/
active_venv/
.venv/
env/
.env/
ENV/
env.bak/
venv.bak/

